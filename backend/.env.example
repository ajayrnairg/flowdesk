# Core app settings
# Name of the FastAPI project
PROJECT_NAME="FlowDesk"

# Database
# The database URL formatted for SQLAlchemy with the asyncpg driver.
# Expected format: postgresql+asyncpg://user:password@host/dbname
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/flowdesk"

# Security
# Secret key used for cryptographic operations such as signing JWT tokens.
# You can generate a secure key using: openssl rand -hex 32
SECRET_KEY="your-super-secret-key-placeholder"

# Algorithm used to sign the JWT tokens (default is HS256)
ALGORITHM="HS256"

# Token validity duration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
